# HexMind environment configuration
# Copy to .env and fill in your API keys

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (optional, via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-...

# Defaults
HEXMIND_DEFAULT_MODEL=gpt-4o
HEXMIND_TOKEN_BUDGET=50000
HEXMIND_LOCALE=zh
HEXMIND_ARCHIVE_DIR=discussion_archive

# Optional asset roots
# Useful when previewing the open-source sample bundle from this private workspace.
# HEXMIND_PERSONAS_DIR=open_source_assets/personas
# HEXMIND_PROMPTS_DIR=open_source_assets/prompts/library
