# HexMind environment configuration
# Copy to .env and fill in your API keys

# Requesty / OpenAI-compatible gateway
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://router.requesty.ai/v1

# Model aliases shown in the frontend
# Hosted demo defaults: GPT-5.4 (built-in trial) + GPT-4o + GPT-4o-mini.
# Anthropic / claude models are not used in the hosted free tier (cost reasons).
HEXMIND_MODEL_MAP=gpt=openai/gpt-5.4,gpt4o=openai/gpt-4o,mini=openai/gpt-4o-mini
HEXMIND_DEFAULT_MODEL_ALIAS=gpt
# Optional: discussion fallback alias during budget degradation.
HEXMIND_FALLBACK_MODEL_ALIAS=mini
HEXMIND_TOKEN_BUDGET=50000
HEXMIND_DISCUSSION_LOCALE=zh

# ─── Hosted-trial guardrails (enforced when DATABASE_URL is set) ──────
# How many free built-in-key trials each anonymous visitor (IP + UA hash) gets.
# Set to 0 to disable the trial entirely (BYOK-only mode).
HEXMIND_TRIAL_LIMIT_PER_VISITOR=1
# Global daily USD circuit-breaker for anonymous trial spend (in USD, decimal).
# When today's accumulated spend exceeds this, all trial requests return 402.
HEXMIND_DAILY_USD_LIMIT=3.0

# ─── Demo mode (zero-cost preview) ────────────────────────────────────
# When true, ALL LLM calls return canned responses. No provider is hit.
# Use this for GitHub-landing-page previews and waitlist demos. Remember
# to set this back to false (or unset) before serving real traffic.
HEXMIND_DEMO_MODE=false
# Legacy fallback still supported during migration:
# HEXMIND_LOCALE=zh
HEXMIND_ARCHIVE_DIR=discussion_archive

# ─── Authentication provider ──────────────────────────────────────────
# 'local' (default): email + password signed with JWT_SECRET.
# 'clerk':           Clerk-hosted auth (RS256 JWTs + webhooks).
HEXMIND_AUTH_PROVIDER=local
# Required when HEXMIND_AUTH_PROVIDER=local (any long random string):
JWT_SECRET=change-me-to-a-long-random-string

# ─── Clerk (only needed when HEXMIND_AUTH_PROVIDER=clerk) ─────────────
# Publishable key (safe to expose to frontend). Copy to web/.env as
# VITE_CLERK_PUBLISHABLE_KEY too.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Backend-only secret. NEVER expose to frontend.
# CLERK_SECRET_KEY=sk_test_...
# Issuer URL for JWT verification. Find it in Clerk Dashboard →
# "API Keys" → "Show JWT public key" → Issuer, e.g.
# https://teaching-catfish-43.clerk.accounts.dev
# CLERK_JWT_ISSUER=
# Webhook signing secret from Clerk Dashboard → "Webhooks" → your endpoint.
# Format: whsec_XXXXXXXXXXXX
# CLERK_WEBHOOK_SECRET=

# Optional asset roots
# Useful when previewing the open-source sample bundle from this private workspace.
# HEXMIND_PERSONAS_DIR=open_source_assets/personas
# HEXMIND_PROMPTS_DIR=open_source_assets/prompts/library
